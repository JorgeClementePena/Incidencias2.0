PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nc_manager
DB_USER=root
DB_PASSWORD=root123

# JWT
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_algo_largo_y_aleatorio

# Admin bootstrap opcional
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrador
BOOTSTRAP_ADMIN_DEPARTMENT=Calidad

# CORS opcional
# Lista de origenes permitidos, separados por comas.
CORS_ORIGIN=

# Email SMTP (opcional; sin esto los emails se muestran solo en consola)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx_xxxx_xxxx_xxxx
