# ── Aplicación ────────────────────────────────────────────────
APP_PORT=3000

# ── Base de datos ─────────────────────────────────────────────
DB_NAME=nc_manager
DB_USER=nc_user
DB_PASSWORD=cambia_esta_password
DB_ROOT_PASSWORD=cambia_root_password

# ── Seguridad JWT ─────────────────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_algo_largo_y_aleatorio

# Admin bootstrap opcional
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrador
BOOTSTRAP_ADMIN_DEPARTMENT=Calidad

# CORS opcional
# Lista de origenes permitidos, separados por comas.
CORS_ORIGIN=

# ── Email SMTP (opcional) ─────────────────────────────────────
# Sin esto los emails se muestran solo en consola
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx_xxxx_xxxx_xxxx
# EMAIL_FROM=noreply@tuempresa.com
